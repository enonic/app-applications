{
  "name": "app-applications",
  "version": "1.0.0",
  "description": "Enonix XP - Applications App",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/enonic/app-applications"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm build:dev",
    "build:prod": "pnpm run \"/^build:prod:.*$/\"",
    "build:prod:js": "cross-env BUILD_TARGET=js vite build --mode production",
    "build:prod:css": "cross-env BUILD_TARGET=css vite build --mode production",
    "build:dev": "pnpm run \"/^build:dev:.*$/\"",
    "build:dev:js": "cross-env BUILD_TARGET=js vite build --mode development",
    "build:dev:css": "cross-env BUILD_TARGET=css vite build --mode development",
    "build:prod:tailwind": "vite build --config vite.config.css.mjs --mode production",
    "build:dev:tailwind": "vite build --config vite.config.css.mjs --mode development",
    "check": "pnpm run \"/^check:.*$/\"",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint . --quiet --cache",
    "fix": "eslint --fix **/*.ts"
  },
  "dependencies": {
    "@enonic/lib-admin-ui": "file:./.xp/dev/lib-admin-ui",
    "@enonic/ui": "~1.0.0-beta.1",
    "@nanostores/preact": "^1.0.0",
    "@radix-ui/react-slot": "^1.2",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "focus-trap-react": "^11.0",
    "jquery": "^3.7.1",
    "lucide-react": "^0.577",
    "nanostores": "^0.11.4",
    "preact": "^10.29",
    "q": "^1.5.1",
    "tailwind-merge": "^3.0"
  },
  "devDependencies": {
    "@enonic/eslint-config": "^2.1.0",
    "@rollup/plugin-inject": "^5.0.5",
    "@types/postcss-normalize": "^9.0.4",
    "@types/q": "^1.5.8",
    "autoprefixer": "^10.4.21",
    "browserslist-config-enonic": "^1.0.8",
    "cross-env": "^10.0.0",
    "cssnano": "^7.1.0",
    "enonic-admin-artifacts": "^2.3.2",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "jiti": "^2.5.1",
    "less": "^4.6.4",
    "postcss-normalize": "^13.0.1",
    "postcss-sort-media-queries": "^5.2.0",
    "tailwindcss": "^4.3",
    "@tailwindcss/vite": "^4.3",
    "tw-animate-css": "^1.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "8.40.0",
    "vite": "^7.1.2"
  },
  "browserslist": [
    "extends browserslist-config-enonic"
  ],
  "engines": {
    "node": ">= 24.14.1",
    "pnpm": ">= 11.1.1",
    "npm": ">= 11.6.2"
  }
}
